---
import '../index.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Carlos Gutierrez - Software Engineer",
  description =
    "Portfolio and blog of Carlos Gutierrez, a Software Engineer passionate about building products from the ground up.",
} = Astro.props;
