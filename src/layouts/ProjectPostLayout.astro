---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';

interface Props {
  frontmatter?: {
    title?: string;
    date?: string;
    description?: string;
  };
}

const { frontmatter = {} } = Astro.props;
const title = frontmatter.title || 'Untitled';
const date = frontmatter.date || '';
const description = frontmatter.description;
---

<BaseLayout title={`${title} - Carlos Gutierrez`}>
  <div class="min-h-screen bg-background flex flex-col">
    <Header />
    
    <main class="flex-1 max-w-4xl mx-auto w-full px-8 py-12">
      <a 
        href="/projects"
        class="inline-flex items-center gap-2 text-xs font-mono text-muted-foreground hover:text-foreground uppercase tracking-wider transition-colors mb-8"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Projects
      </a>

      <article class="border-t-2 border-border pt-8">
        <header class="mb-8">
          <h1 class="text-3xl md:text-4xl font-bold text-foreground tracking-tight mb-4">{title}</h1>
          <time class="text-xs font-mono text-muted-foreground uppercase tracking-wider mb-4 block">{date}</time>
          {description && (
            <p class="text-sm font-mono text-foreground">{description}</p>
          )}
        </header>

        <div class="prose prose-lg max-w-none prose-headings:font-bold prose-headings:tracking-tight prose-p:font-mono prose-p:text-sm prose-a:text-primary prose-a:no-underline hover:prose-a:underline prose-strong:font-semibold prose-ul:font-mono prose-ol:font-mono prose-li:text-sm">
          <slot />
        </div>
      </article>
    </main>
  </div>
</BaseLayout>
