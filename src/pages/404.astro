---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <div class="flex flex-1 min-h-[60vh] items-center justify-center bg-background">
    <div class="text-center px-8">
      <h1 class="text-6xl font-bold text-foreground font-mono mb-4">404</h1>
      <p class="text-sm font-mono text-muted-foreground uppercase tracking-wider mb-6">Page not found</p>
      <a href="/" class="inline-block text-primary font-mono text-sm uppercase tracking-wider border-2 border-primary px-4 py-2 hover:bg-primary hover:text-primary-foreground transition-colors">
        Return to Home
      </a>
    </div>
  </div>
</BaseLayout>
