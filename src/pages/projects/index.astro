---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import { processMDXFiles } from '@/lib/utils';

let allProjects = [];
try {
  allProjects = await Astro.glob('./*.mdx');
} catch {
  allProjects = [];
}
const projects = processMDXFiles(allProjects);
---

<BaseLayout title="Projects - Carlos Gutierrez">
  <div class="min-h-screen bg-background flex flex-col">
    <Header />
    
    <main class="flex-1 max-w-4xl mx-auto w-full px-8 py-12">
      <div class="border-b-2 border-border pb-4 mb-0">
        <h1 class="text-3xl font-bold text-foreground tracking-tight">Projects</h1>
        <p class="text-xs font-mono text-muted-foreground uppercase tracking-widest mt-2">Portfolio</p>
      </div>
      
      {projects.length > 0 ? (
        <div class="border-2 border-border border-t-0">
          <div class="grid grid-cols-1 md:grid-cols-12 gap-0 bg-foreground text-background font-mono text-xs uppercase tracking-wider px-6 py-3">
            <div class="md:col-span-2">Project</div>
            <div class="md:col-span-8">Title</div>
            <div class="md:col-span-2">Date</div>
          </div>
          {projects.map((project, i) => (
            <a 
              href={`/projects/${project.slug}`} 
              class="block border-t-2 border-border hover:bg-muted/50 transition-colors"
            >
              <div class="grid grid-cols-1 md:grid-cols-12 gap-0 px-6 py-4 items-center font-mono text-sm">
                <div class="md:col-span-2 text-muted-foreground text-xs">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <div class="md:col-span-8 font-semibold text-foreground">
                  {project.title}
                </div>
                <div class="md:col-span-2 text-muted-foreground text-xs">
                  {project.date}
                </div>
              </div>
              <div class="px-6 pb-2 flex justify-end">
                <svg class="w-4 h-4 text-muted-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="border-2 border-border p-12 text-center">
          <p class="font-mono text-muted-foreground">No projects yet. Check back soon.</p>
        </div>
      )}
    </main>
  </div>
</BaseLayout>
